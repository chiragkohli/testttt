{
  "name": "@ecommerce/search-service",
  "version": "1.0.0",
  "description": "Full-text search and product indexing service",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "dev": "node src/server.js",
    "start": "node src/server.js",
    "test": "jest --detectOpenHandles --forceExit",
    "test:unit": "jest --testPathPattern='\\.test\\.js$' --detectOpenHandles --forceExit",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --forceExit"
  },
  "jest": {
    "testPathIgnorePatterns": ["<rootDir>/node_modules/"],
    "collectCoverageFrom": ["src/**/*.js", "!src/**/*.test.js", "!src/**/*.spec.js"]
  },
  "dependencies": {
    "@ecommerce/shared": "workspace:*",
    "express": "^4.18.2",
    "@elastic/elasticsearch": "^8.10.0",
    "kafkajs": "^2.2.4",
    "joi": "^17.11.0",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.6",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "supertest": "^6.3.3"
  }
}
