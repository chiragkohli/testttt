# Environment variables template - Copy and configure for each environment
# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres_password
DB_NAME=ecommerce_users

# MongoDB Configuration
MONGO_URI=mongodb://localhost:27017/ecommerce_products

# Elasticsearch Configuration
ELASTICSEARCH_URL=http://localhost:9200

# Kafka Configuration
KAFKA_BROKER=localhost:9092
KAFKA_CLIENT_ID=default-client
KAFKA_GROUP_ID=default-group

# Service URLs (for API Gateway)
USER_SERVICE_URL=http://localhost:3001
PRODUCT_SERVICE_URL=http://localhost:3002
SEARCH_SERVICE_URL=http://localhost:3003

# Authentication & Security
JWT_SECRET=your-very-secret-key-change-in-production-immediately
JWT_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# Application Configuration
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# API Gateway Configuration
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Redis (future use)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
